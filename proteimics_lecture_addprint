<!DOCTYPE html>

<html lang="ko">
<head>
<meta charset="utf-8"/>
<title>Claude와 함께하는 단백체 분석 시각화</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap" rel="stylesheet"/>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
  width: 100%; height: 100%;
  background: #0f172a;
  overflow: hidden;
  font-family: 'Noto Sans KR', sans-serif;
}

/* 스케일 컨테이너 */
.deck {
  width: 100vw; height: 100vh;
  display: flex; align-items: center; justify-content: center;
}

.slide-wrapper {
  width: 1280px; height: 720px;
  transform-origin: center center;
  position: relative; overflow: hidden;
  flex-shrink: 0;
}

/* 슬라이드 */
.slide {
  position: absolute; inset: 0;
  background: #fff;
  display: none; flex-direction: column;
}
.slide.active { display: flex; }

/* 헤더 바 */
.slide-header {
  background: #1e3a5f; color: #fff;
  padding: 18px 48px;
  display: flex; align-items: center; gap: 14px;
  flex-shrink: 0;
}
.accent-bar { width: 5px; height: 28px; background: #4fd1c5; border-radius: 3px; }
.slide-header h2 { font-size: 26px; font-weight: 500; letter-spacing: -0.01em; }

/* 본문 */
.slide-body {
  flex: 1; padding: 32px 52px;
  display: flex; flex-direction: column; justify-content: center;
  overflow: hidden;
}

/* ── 표지 ── */
.slide.cover {
  background: linear-gradient(140deg, #1a3356 0%, #0d1e38 60%, #0f172a 100%);
  align-items: flex-start; justify-content: center; padding: 60px 72px;
}
.cover .eyebrow {
  color: #4fd1c5; font-size: 15px; font-weight: 600;
  letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 20px;
}
.cover h1 {
  color: #f8fafc; font-size: 52px; font-weight: 700;
  line-height: 1.15; letter-spacing: -0.02em;
  margin-bottom: 18px; max-width: 72%;
}
.cover .subtitle {
  color: #94a3b8; font-size: 22px; font-weight: 300;
  line-height: 1.6; margin-bottom: 52px; max-width: 68%;
}
.cover .meta {
  display: flex; gap: 44px;
  border-top: 1px solid #1e3a5f; padding-top: 26px;
}
.cover .meta-item { color: #475569; font-size: 16px; }
.cover .meta-item span { color: #94a3b8; display: block; margin-top: 4px; font-weight: 500; font-size: 17px; }
.cover .deco {
  position: absolute; right: 56px; top: 50%; transform: translateY(-50%);
  opacity: 0.06; font-size: 340px; font-weight: 900; color: #fff;
  line-height: 1; user-select: none;
  font-family: 'JetBrains Mono', monospace; letter-spacing: -0.05em;
}

/* ── 공통 텍스트 ── */
.lead { font-size: 22px; color: #1e293b; margin-bottom: 22px; line-height: 1.55; }
p.body { font-size: 20px; color: #334155; line-height: 1.65; margin-bottom: 12px; }

/* ── 테이블 ── */
table { width: 100%; border-collapse: collapse; font-size: 19px; }
th {
  background: #1e3a5f; color: #fff;
  padding: 13px 18px; text-align: left; font-weight: 500;
}
td { padding: 12px 18px; border-bottom: 1px solid #e2e8f0; color: #334155; vertical-align: middle; }
tr:nth-child(even) td { background: #f8fafc; }
tr:last-child td { border-bottom: none; }
.td-time { color: #0ea5e9; font-weight: 700; white-space: nowrap; font-size: 20px; }

/* ── 카드 그리드 ── */
.card-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px; }
.card {
  background: #f8fafc; border: 1px solid #e2e8f0;
  border-left: 5px solid #f87171; border-radius: 8px; padding: 20px 24px;
}
.card h3 { font-size: 20px; font-weight: 600; color: #1e293b; margin-bottom: 8px; }
.card p  { font-size: 18px; color: #64748b; line-height: 1.5; }

/* ── 비교 레이아웃 ── */
.compare { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.compare-box {
  background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 10px; padding: 24px 26px;
}
.compare-box.old { border-top: 4px solid #f87171; }
.compare-box.new { border-top: 4px solid #4fd1c5; }
.box-label {
  font-size: 14px; font-weight: 700; letter-spacing: 0.08em;
  text-transform: uppercase; margin-bottom: 16px;
}
.compare-box.old .box-label { color: #dc2626; }
.compare-box.new .box-label { color: #0d9488; }

/* ── 불릿 리스트 ── */
.bullets { list-style: none; padding: 0; }
.bullets li {
  padding: 9px 0; font-size: 19px; color: #334155;
  border-bottom: 1px solid #f1f5f9;
  display: flex; align-items: flex-start; gap: 10px; line-height: 1.4;
}
.bullets li:last-child { border-bottom: none; }
.bullets li::before  { content: '▸'; color: #4fd1c5; flex-shrink: 0; }
.bullets li.x::before  { content: '✗'; color: #f87171; }
.bullets li.ok::before { content: '✓'; color: #10b981; }

/* ── 코드 블록 ── */
pre {
  background: #0f172a; color: #e2e8f0;
  border-radius: 10px; padding: 22px 26px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 17px; line-height: 1.7; white-space: pre-wrap;
}
.cmt { color: #64748b; font-style: italic; }
.str { color: #86efac; }

/* ── 하이라이트 박스 ── */
.highlight {
  background: #f0f9ff; border: 1px solid #bae6fd;
  border-left: 5px solid #0ea5e9; border-radius: 8px;
  padding: 16px 22px; font-size: 20px; color: #0c4a6e; line-height: 1.6;
}
.highlight.warn {
  background: #fff1f2; border-color: #fca5a5; border-left-color: #f87171; color: #7f1d1d;
}

/* ── 태그 ── */
.tag {
  display: inline-block; padding: 5px 13px;
  border-radius: 5px; font-size: 16px; font-weight: 600; margin: 3px 2px;
}

/* ── 흐름 화살표 ── */
.flow {
  display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
  font-size: 19px; color: #334155; margin: 14px 0;
}
.flow .arr { color: #4fd1c5; font-size: 20px; }

/* ── 데이터 소개용 큰 카드 ── */
.data-card {
  background: #f8fafc; border: 1px solid #e2e8f0;
  border-radius: 10px; padding: 24px 28px;
  border-left: 6px solid;
}
.data-card.hcc  { border-left-color: #0ea5e9; }
.data-card.pxd  { border-left-color: #f59e0b; }
.data-card h3 { font-size: 22px; font-weight: 700; color: #1e293b; margin-bottom: 8px; }
.data-card .sub { font-size: 17px; color: #64748b; margin-bottom: 14px; }
.data-card .stats { display: flex; gap: 28px; }
.data-card .stat-item .num { font-size: 28px; font-weight: 700; }
.data-card.hcc  .stat-item .num { color: #0369a1; }
.data-card.pxd  .stat-item .num { color: #b45309; }
.data-card .stat-item .lbl { font-size: 15px; color: #64748b; margin-top: 2px; }

/* ── 하단 UI ── */
.progress-bar {
  position: absolute; bottom: 0; left: 0; height: 4px;
  background: #4fd1c5; transition: width 0.3s ease; z-index: 10;
}
.slide-counter {
  position: absolute; bottom: 12px; right: 20px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 15px; color: #64748b; z-index: 10;
}
.nav-hint {
  position: absolute; bottom: 12px; left: 20px;
  font-size: 14px; color: #94a3b8; z-index: 10;
}


