/* cytoscape 인스턴스 */
var _cy1 = null, _cy2 = null;

function _makeCy(cid, elements, seedBorder) {
  return cytoscape({
    container: document.getElementById(cid),
    elements: elements,
    layout: {name:'preset', fit:true, padding:28},
    style: [
      {selector:'node', style:{
        'label': function(e){ return e.data('is_seed') ? e.data('label')+'★' : e.data('label'); },
        'background-color': 'data(color)',
        'width':  function(e){ var n=e.data('neglogfdr')||1, s=e.data('is_seed'); return (s?30:18)+Math.min(n*3,14); },
        'height': function(e){ var n=e.data('neglogfdr')||1, s=e.data('is_seed'); return (s?30:18)+Math.min(n*3,14); },
        'border-width':  function(e){ return e.data('is_seed') ? 2.5 : 1; },
        'border-color':  function(e){ return e.data('is_seed') ? seedBorder : '#94a3b8'; },
        'font-size':     function(e){ return e.data('is_seed') ? 11 : 9; },
        'font-weight':   function(e){ return e.data('is_seed') ? 'bold' : 'normal'; },
        'text-valign':'center', 'text-halign':'center',
        'color':'#1e293b', 'text-outline-width':1.5,
        'text-outline-color':'rgba(255,255,255,0.9)', 'cursor':'pointer'
      }},
      {selector:'node:selected', style:{'border-width':3, 'border-color':'#fbbf24'}},
      {selector:'edge', style:{
        'width':'data(width)', 'line-color':'data(ecolor)',
        'opacity':0.75, 'curve-style':'bezier'
      }},
      {selector:'edge:selected', style:{'opacity':1}}
    ],
    wheelSensitivity: 0.3,
    minZoom: 0.3, maxZoom: 4
  });
}

function _bindInfo(cy, pfx) {
  cy.on('tap', 'node', function(e) {
    var d = e.target.data();
    document.getElementById(pfx+'ig').textContent = d.label + (d.is_seed ? ' ★' : '');
    document.getElementById(pfx+'iz').textContent = 'Z-score: ' + d.z;
    document.getElementById(pfx+'if').textContent = 'log₂FC: ' + (d.fc >= 0 ? '+' : '') + d.fc;
    document.getElementById(pfx+'ip').textContent = 'FDR: ' + (d.fdr < 0.001 ? '<0.001' : d.fdr);
    document.getElementById(pfx+'id').textContent = '연결 수: ' + e.target.degree();
    document.getElementById(pfx+'info').classList.add('on');
  });
  cy.on('tap', function(evt) {
    if (evt.target === cy) document.getElementById(pfx+'info').classList.remove('on');
  });
}

/* ★ 합본·standalone 공용 초기화 함수 */
window.initPPI = function() {
  if (_cy1 || _cy2) return;  /* 이미 초기화된 경우 건너뜀 */
  _cy1 = _makeCy('cy1', _PPI_C1, '#7f1d1d');
  _cy2 = _makeCy('cy2', _PPI_C2, '#1e3a8a');
  var c1n = document.getElementById('c1n');
  var c1e = document.getElementById('c1e');
  var c2n = document.getElementById('c2n');
  var c2e = document.getElementById('c2e');
  if (c1n) c1n.textContent = _cy1.nodes().length;
  if (c1e) c1e.textContent = _cy1.edges().length;
  if (c2n) c2n.textContent = _cy2.nodes().length;
  if (c2e) c2e.textContent = _cy2.edges().length;
  _bindInfo(_cy1, 'c1');
  _bindInfo(_cy2, 'c2');
  var b1 = document.getElementById('b1fit');
  var b2 = document.getElementById('b2fit');
  if (b1) b1.onclick = function(){ _cy1.fit(null, 28); };
  if (b2) b2.onclick = function(){ _cy2.fit(null, 28); };
};

/* ★ standalone 전용 네비게이션
   합본에서는 .slide 수가 많으므로 실행되지 않음 */
(function() {
  var allSlides = document.querySelectorAll('#wrapper > .slide');
  if (allSlides.length > 5) return;  /* 합본이면 건너뜀 */

  var prog = document.getElementById('prog');
  var cnt  = document.getElementById('cnt');
  var wrap = document.getElementById('wrapper');
  var cur  = 0;

  function scale() {
    var s = Math.min(window.innerWidth/1280, window.innerHeight/720);
    wrap.style.transform = 'scale(' + s + ')';
  }
  window.addEventListener('resize', scale);

  function go(n) {
    allSlides[cur].classList.remove('active');
    cur = Math.max(0, Math.min(allSlides.length-1, n));
    allSlides[cur].classList.add('active');
    prog.style.width = ((cur+1)/allSlides.length*100) + '%';
    cnt.textContent  = (cur+1) + ' / ' + allSlides.length;
  }

  document.addEventListener('keydown', function(e) {
    if (['ArrowRight','ArrowDown',' '].includes(e.key)) { e.preventDefault(); go(cur+1); }
    if (['ArrowLeft','ArrowUp'].includes(e.key))        { e.preventDefault(); go(cur-1); }
  });
  document.querySelector('.deck').addEventListener('click', function(e) {
    if (e.target.closest('.side') || e.target.closest('.ctrl-btn') ||
        e.target.closest('#cy1') || e.target.closest('#cy2')) return;
    go(cur+1);
  });

  window.addEventListener('load', function() {
    scale();
    window.initPPI();
    go(0);
  });
})();

