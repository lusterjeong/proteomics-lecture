const counter=document.getElementById('counter');
const wrapper=document.getElementById('wrapper');
let cur=0;
const PPI_INDICES=new Set([48, 49]);
let ppiInited=false;
function scale(){const s=Math.min(window.innerWidth/1280,window.innerHeight/720);wrapper.style.transform=`scale(${s})`;}
window.addEventListener('resize',scale);scale();
function go(n){slides[cur].classList.remove('active');cur=Math.max(0,Math.min(slides.length-1,n));slides[cur].classList.add('active');progress.style.width=((cur+1)/slides.length*100)+'%';counter.textContent=(cur+1)+' / '+slides.length;if(PPI_INDICES.has(cur)&&!ppiInited){ppiInited=true;setTimeout(()=>{if(typeof initPPI==='function')initPPI();},50);}}
document.addEventListener('keydown',e=>{if(['ArrowRight','ArrowDown',' '].includes(e.key)){e.preventDefault();go(cur+1);}if(['ArrowLeft','ArrowUp'].includes(e.key)){e.preventDefault();go(cur-1);}});
document.querySelector('.deck').addEventListener('click',e=>{if(e.target.closest('.side')||e.target.closest('.ctrl-btn')||e.target.closest('#cy1')||e.target.closest('#cy2'))return;go(cur+1);});
