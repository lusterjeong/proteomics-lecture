    display: flex !important;
    position: relative !important;
    page-break-after: always;
  }
  .slide.active {
    display: flex !important;
  }
  .deck, .slide-wrapper {
    height: auto !important;
    width: 100% !important;
  }
  .progress-bar, .slide-counter, .nav-hint {
    display: none !important;
